+#[test]
+fn client_maximize() {
+    let mut f = Fixture::new();
+    let mut connection = Connection::new(&f.display);
+
+    let window = connection.new_window(connection.root, 0, 0, 20, 20, false);
+    let surface = f.map_as_toplevel(&mut connection, window);
+
+    let allowed_actions = connection.get_atom_property(window, connection.atoms.wm_allowed_actions);
+    assert!(allowed_actions.contains(&connection.atoms.wm_action_minimize));
+    assert!(allowed_actions.contains(&connection.atoms.wm_action_maximize_horz));
+    assert!(allowed_actions.contains(&connection.atoms.wm_action_maximize_vert));
+
+    let request_maximized = |connection: &Connection, state: SetState| {
+        connection.send_client_message(&x::ClientMessageEvent::new(
+            window,
+            connection.atoms.net_wm_state,
+            x::ClientMessageData::Data32([
+                state as u32,
+                connection.atoms.wm_maximized_horz.resource_id(),
+                connection.atoms.wm_maximized_vert.resource_id(),
+                1,
+                0,
+            ]),
+        ));
+    };
+
+    let assert_maximized = |f: &Fixture, connection: &Connection, expected: bool| {
+        let wayland_maximized = f
+            .testwl
+            .get_surface_data(surface)
+            .unwrap()
+            .toplevel()
+            .states
+            .contains(&xdg_toplevel::State::Maximized);
+        assert_eq!(wayland_maximized, expected);
+
+        let x11_states = connection.get_atom_property(window, connection.atoms.net_wm_state);
+        assert_eq!(
+            x11_states.contains(&connection.atoms.wm_maximized_horz),
+            expected
+        );
+        assert_eq!(
+            x11_states.contains(&connection.atoms.wm_maximized_vert),
+            expected
+        );
+    };
+
+    request_maximized(&connection, SetState::Add);
+    f.wait_and_dispatch();
+    assert_maximized(&f, &connection, true);
+
+    request_maximized(&connection, SetState::Remove);
+    f.wait_and_dispatch();
+    assert_maximized(&f, &connection, false);
+
+    request_maximized(&connection, SetState::Toggle);
+    f.wait_and_dispatch();
+    assert_maximized(&f, &connection, true);
+
+    request_maximized(&connection, SetState::Toggle);
+    f.wait_and_dispatch();
+    assert_maximized(&f, &connection, false);
+}
