+#[test]
+fn x11_utf8_string_bridges_wayland_text_mimes() {
+    let mut f = Fixture::new();
+    let mut connection = Connection::new(&f.display);
+    let window = connection.new_window(connection.root, 0, 0, 20, 20, false);
+    f.map_as_toplevel(&mut connection, window);
+
+    let utf8_string = connection
+        .get_reply(&x::InternAtom {
+            only_if_exists: false,
+            name: b"UTF8_STRING",
+        })
+        .atom();
+
+    connection.set_selection_owner(window, connection.atoms.clipboard);
+    let request = connection.await_selection_request();
+    assert_eq!(request.target(), connection.atoms.targets);
+    connection.set_property(
+        request.requestor(),
+        x::ATOM_ATOM,
+        request.property(),
+        &[utf8_string],
+    );
+    connection.send_selection_notify(&request);
+    f.wait_and_dispatch();
+
+    let mut mimes = f.testwl.data_source_mimes();
+    mimes.sort();
+    assert_eq!(
+        mimes,
+        ["UTF8_STRING", "text/plain", "text/plain;charset=utf-8"]
+    );
+
+    let payload = b"QQ-\xe8\x81\x8a\xe5\xa4\xa9";
+    let data = f.testwl.clipboard_paste_data(|mime, _| {
+        let request = connection.await_selection_request();
+        assert_eq!(request.target(), utf8_string, "Wayland MIME {mime}");
+        connection.set_property(
+            request.requestor(),
+            utf8_string,
+            request.property(),
+            payload,
+        );
+        connection.send_selection_notify(&request);
+        true
+    });
+
+    assert_eq!(data.len(), 3);
+    for item in data {
+        assert_eq!(item.data, payload, "Wayland MIME {}", item.mime_type);
+    }
+}
