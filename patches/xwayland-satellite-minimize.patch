+    assert!(allowed_actions.contains(&connection.atoms.wm_action_maximize_vert));
+
+    let request_maximized = |connection: &Connection, state: SetState| {
+        connection.send_client_message(&x::ClientMessageEvent::new(
+            window,
+            connection.atoms.net_wm_state,
+            x::ClientMessageData::Data32([
+                state as u32,
+                connection.atoms.wm_maximized_horz.resource_id(),
+                connection.atoms.wm_maximized_vert.resource_id(),
+                1,
+                0,
+            ]),
