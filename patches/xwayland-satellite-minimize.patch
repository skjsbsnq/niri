+        if let Some(offer) = T::take_offer(&mut events.offer) {
+            // Wayland selections do not cancel old data offers when a different
+            // Wayland client replaces the clipboard. Keep X11-owned selections
+            // until the compositor cancels our source, but always refresh stale
+            // foreign offers.
+            if selection_cancelled || !matches!(state.source, Some(SelectionData::X11 { .. })) {
+                let mime_types = T::get_mimes(&offer);
+                let foreign = ForeignSelection {
+                    mime_types,
+                    inner: offer,
+                };
+                state.source = Some(SelectionData::Foreign(foreign));
+            }
         }
     }
 
