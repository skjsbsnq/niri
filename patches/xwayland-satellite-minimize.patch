+    let win = Window::new(1);
+    let (buffer, surface) = comp.create_surface();
+    f.new_window(
+        win,
+        false,
+        WindowData {
+            mapped: true,
+            dims: WindowDims {
+                x: 0,
+                y: 0,
+                width: 50,
+                height: 50,
+            },
+            fullscreen: false,
+        },
+    );
+    f.satellite.set_initial_maximized(win, true);
+    f.map_window(&comp, win, &surface.obj, &buffer);
+    f.run();
+    f.run();
+
+    let id = f.check_new_surface();
+    let data = f.testwl.get_surface_data(id).unwrap();
+    assert!(
+        data.toplevel()
+            .states
+            .contains(&xdg_toplevel::State::Maximized)
+    );
+    assert!(f.connection().maximized_windows.contains(&win));
+}
