+    assert_maximized(&f, &connection, true);
+
+    request_maximized(&connection, SetState::Remove);
+    f.wait_and_dispatch();
+    assert_maximized(&f, &connection, false);
+
+    request_maximized(&connection, SetState::Toggle);
+    f.wait_and_dispatch();
+    assert_maximized(&f, &connection, true);
+
