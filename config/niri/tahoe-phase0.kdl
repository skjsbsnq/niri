// Phase 0 Tahoe prototype config.
//
// Keep this file source-only and deploy it to ~/.config/niri/tahoe/config.kdl
// through scripts/arch-update.sh. It intentionally does not replace the
// user's default ~/.config/niri/config.kdl.

// tahoe-managed: begin input
input {
    keyboard {
        xkb {}
        numlock
    }

    touchpad {
        tap
        natural-scroll
    }
}
// tahoe-managed: end input

output "eDP-2" {
    mode "2560x1600@239.998"
    scale 1.25
    transform "normal"
    position x=0 y=0
    // Keep the panel at its native 239.998 Hz fixed refresh.
    // VRR is intentionally off (variable-refresh-rate disabled).
    // variable-refresh-rate
}

// tahoe-managed: begin layout
layout {
    gaps 16
    center-focused-column "never"
    default-column-width { proportion 0.5; }

    focus-ring {
        off
    }

    border {
        off
    }

    shadow {
        on
        softness 60
        spread 6
        offset x=0 y=18
        color "#0007"
        inactive-color "#0004"
    }

    snap-assist {
        on
        threshold 16
        preview-color "#78beff40"
        preview-border-color "#78beffb4"
    }
}
// tahoe-managed: end layout

// tahoe-managed: begin blur
blur {
    on
    passes 4
    offset 4
    noise 0.004
    saturation 1.22
}
// tahoe-managed: end blur

// tahoe-managed: begin tahoe-glass
tahoe-glass {
    // Every liquid-glass material samples the composed framebuffer directly
    // behind its region. The xray buffer contains only the workspace backdrop
    // and background layers, so enabling it makes glass ignore ordinary
    // windows and visibly retain the wallpaper color.
    //
    // Phase 2/3/4: enable real liquid material. edge-highlight drives the
    // shader's rim/specular light (postprocess.frag glass_light_strength,
    // clamped to 2.0); refraction drives the rounded-SDF-normal sample offset
    // (niri_refraction_offset, clamped to 0.12). contrast is a readability
    // token with 1.0 as no-op, applied after tint. Phase 4 adds:
    //   inner-shadow — SDF-normal inner edge darkening (clamped 0.5);
    //   chromatic    — RGB-split on the refraction sample (clamped 0.1);
    //   lens-depth   — center radial lens bulge (clamped 0.3).
    // Together these move the glass from "frosted white card" to a controlled
    // scene material with edge light, inner shadow and optional lens depth.
    // Built-in defaults mirror this scene vocabulary, while this file is the
    // deployed tuning source. When a surface commits TahoeGlass regions, niri
    // renders through these materials and SKIPS the layer-rule background-effect
    // blocks below, which only serve the
    // BackgroundEffect.blurRegion fallback path.
    //
    // T11 keeps the compositor material vocabulary aligned with
    // TahoeGlass.js and the settings helper:
    // panel, pill, launcher, dock, menu, toast, backdrop.
    // chromatic stays at 0.0 by default so text does not pick up color fringes.
    material "panel" {
        xray false
        noise 0.005
        saturation 1.10
        tint-color "#ffffff"
        tint-amount 0.105
        contrast 1.10
        edge-highlight 0.14
        refraction 0.004
        inner-shadow 0.06
        chromatic 0.0
        lens-depth 0.0
    }
    material "pill" {
        xray false
        noise 0.005
        saturation 1.12
        tint-color "#ffffff"
        tint-amount 0.052
        contrast 1.05
        edge-highlight 0.32
        refraction 0.013
        inner-shadow 0.07
        chromatic 0.0
        lens-depth 0.010
    }
    material "launcher" {
        xray false
        noise 0.005
        saturation 1.08
        tint-color "#ffffff"
        tint-amount 0.085
        contrast 1.08
        edge-highlight 0.15
        refraction 0.004
        inner-shadow 0.055
        chromatic 0.0
        lens-depth 0.003
    }
    material "dock" {
        xray false
        noise 0.005
        saturation 1.10
        tint-color "#ffffff"
        tint-amount 0.060
        contrast 1.06
        edge-highlight 0.18
        refraction 0.007
        inner-shadow 0.07
        chromatic 0.0
        lens-depth 0.006
    }
    // menu/toast read clearer: controlled edge light, gentler lens distortion.
    material "menu" {
        xray false
        noise 0.004
        saturation 1.08
        tint-color "#ffffff"
        tint-amount 0.110
        contrast 1.11
        edge-highlight 0.26
        refraction 0.004
        inner-shadow 0.10
        chromatic 0.0
        lens-depth 0.0
    }
    material "toast" {
        xray false
        noise 0.005
        saturation 1.09
        tint-color "#ffffff"
        tint-amount 0.100
        contrast 1.10
        edge-highlight 0.24
        refraction 0.005
        inner-shadow 0.09
        chromatic 0.0
        lens-depth 0.0
    }
    // backdrop is for fullscreen scrims/backdrops; keep refraction/lens low
    // so the whole screen does not visibly warp, and keep shadow off (set in
    // code default). glass_surface_detail() also fades these out on big
    // surfaces.
    material "backdrop" {
        xray false
        noise 0.003
        saturation 1.04
        tint-color "#ffffff"
        tint-amount 0.070
        contrast 1.03
        edge-highlight 0.05
        refraction 0.002
        inner-shadow 0.0
        chromatic 0.0
        lens-depth 0.0
        shadow {
            off
        }
    }
}
// tahoe-managed: end tahoe-glass

hotkey-overlay {
    skip-at-startup
}

xwayland-satellite {
    // Built and refreshed by scripts/arch-update.sh from
    // patches/xwayland-satellite-minimize.patch.
    // The legacy filename now carries maximize, minimize, and clipboard
    // compatibility fixes. The wrapper also forces Xwayland glamor,
    // otherwise GLX clients fall back to llvmpipe on this NVIDIA setup.
    path "~/.local/lib/niri/xwayland-satellite-minimize-glamor"
}

environment {
    // Xwayland-satellite on this hybrid NVIDIA setup exposes GLX_EXT_libglvnd,
    // but GLVND defaults GLX clients to Mesa/llvmpipe unless forced.
    __GLX_VENDOR_LIBRARY_NAME "nvidia"

    // Keep Electron apps such as Linux QQ on native Wayland. X11 remains
    // available as an explicit per-app fallback, but fractional Xwayland
    // scaling at 1.25 necessarily resamples buffers and can soften text.
    ELECTRON_OZONE_PLATFORM_HINT "wayland"
}

recent-windows {
    on
    debounce-ms 650
    open-delay-ms 90

    highlight {
        padding 22
        corner-radius 18
        active-color "#d8f6fbff"
        urgent-color "#ffff9a9a"
    }

    previews {
        max-height 430
        max-scale 0.44
    }
}

// Fallback for direct niri launches: xdg-desktop-portal 1.22+ requires this target.
spawn-sh-at-startup "if [ \"${TAHOE_NESTED_SESSION:-0}\" = \"1\" ]; then exit 0; fi; command -v systemd-run >/dev/null 2>&1 && systemd-run --user --unit=tahoe-gsession-activate.service --service-type=oneshot --remain-after-exit --property=Wants=graphical-session.target true >/dev/null 2>&1 || true; command -v systemctl >/dev/null 2>&1 && systemctl --user import-environment WAYLAND_DISPLAY DISPLAY XAUTHORITY XDG_CURRENT_DESKTOP XDG_SESSION_TYPE XDG_SESSION_DESKTOP ELECTRON_OZONE_PLATFORM_HINT __GLX_VENDOR_LIBRARY_NAME QS_ICON_THEME >/dev/null 2>&1 || true"

spawn-sh-at-startup "prestart=\"${TAHOE_CONFIG_DIR:-$HOME/.config/quickshell/tahoe}/scripts/prestart-wallpaper.sh\"; [ -r \"$prestart\" ] && bash \"$prestart\" &"

spawn-sh-at-startup "if [ \"${TAHOE_SKIP_QUICKSHELL_AUTOSTART:-0}\" != \"1\" ]; then launcher=\"${TAHOE_CONFIG_DIR:-$HOME/.config/quickshell/tahoe}/scripts/start-quickshell.sh\"; if [ -r \"$launcher\" ]; then exec bash \"$launcher\"; fi; qs_bin=\"${TAHOE_QUICKSHELL_BIN:-}\"; if [ -z \"$qs_bin\" ]; then if [ -x \"$HOME/.local/bin/quickshell\" ]; then qs_bin=\"$HOME/.local/bin/quickshell\"; else qs_bin=quickshell; fi; fi; exec \"$qs_bin\" -p \"${TAHOE_CONFIG_DIR:-$HOME/.config/quickshell/tahoe}\"; fi"

// Nested previews share the real user's D-Bus session. Replacing Fcitx there
// would strand the desktop input method on the preview's temporary displays.
spawn-sh-at-startup "if [ \"${TAHOE_NESTED_SESSION:-0}\" != \"1\" ]; then exec fcitx5 -d --replace; fi"

// Polkit authentication agent. Guarded so direct niri launches on hosts
// without polkit-gnome don't log a missing-binary error.
spawn-sh-at-startup "if [ \"${TAHOE_NESTED_SESSION:-0}\" != \"1\" ]; then command -v /usr/lib/polkit-gnome/polkit-gnome-authentication-agent-1 >/dev/null 2>&1 && /usr/lib/polkit-gnome/polkit-gnome-authentication-agent-1 & fi"

// tahoe-managed: begin animations
animations {
    workspace-switch {
        spring damping-ratio=0.92 stiffness=420 epsilon=0.0001
    }

    // Window open/close use niri's bounded native scale+fade path. Keeping
    // these finite avoids the large custom-shader draw areas and spring tails
    // that made short lifecycle animations stutter at high refresh rates.
    // They remain intentionally outside motion-profile management.
    window-open {
        duration-ms 220
        curve "ease-out-cubic"
        scale-from 0.94
    }

    window-close {
        duration-ms 180
        curve "ease-out-cubic"
        scale-to 0.94
    }

    window-movement {
        spring damping-ratio=0.8 stiffness=480 epsilon=0.001
    }

    // T04: dedicated genie minimize/restore timing, decoupled from
    // window-close/open (when these nodes are absent the fork falls back to
    // close/open). Like window-open/close they are not motion-profile managed.
    window-minimize {
        duration-ms 280
        curve "cubic-bezier" 0.32 0.0 0.18 1.0
    }

    window-restore {
        // The genie shader already owns the two-phase shape easing. A linear
        // driver preserves its Dock-sized first frame instead of jumping to
        // ~20% progress on the first 240 Hz presentation.
        duration-ms 300
        curve "linear"
    }

    window-resize {
        spring damping-ratio=0.96 stiffness=700 epsilon=0.0005
    }

    overview-open-close {
        spring damping-ratio=0.95 stiffness=760 epsilon=0.0005
    }
}
// tahoe-managed: end animations

window-rule {
    open-floating true
    geometry-corner-radius 22
    clip-to-geometry true

    // Keep in sync with layout.shadow: this rule matches every window, so its
    // shadow is the effective one.
    shadow {
        on
        softness 60
        spread 6
        offset x=0 y=18
        color "#0007"
        inactive-color "#0004"
    }

    background-effect {
        xray false
        blur true
        noise 0.012
        saturation 1.62
        tint-color "#f4fbff"
        tint-amount 0.10
        edge-highlight 0.58
        refraction 0.032
    }

    popups {
        geometry-corner-radius 16

        background-effect {
            blur true
            noise 0.010
            saturation 1.58
            tint-color "#fffafd"
            tint-amount 0.13
            edge-highlight 0.64
            refraction 0.030
        }
    }
}

window-rule {
    match is-active=false

    // Inactive windows carry a visibly weaker shadow (ShadowRule merge
    // overrides softness only; color comes from inactive-color above).
    shadow {
        softness 40
    }

    background-effect {
        blur true
        noise 0.009
        saturation 1.32
        tint-color "#f5f8ff"
        tint-amount 0.06
        edge-highlight 0.30
        refraction 0.014
    }
}

// Phase 1 glass rules are explicit per Tahoe namespace. Large transparent
// containers (tahoe-topbar, tahoe-dock, tahoe-spotlight) and the fullscreen
// backdrop (tahoe-launchpad) intentionally do not get layer-level shadow or
// geometry-wide glass here; their visual glass is inside the surface.
layer-rule {
    match namespace="^tahoe-control-center$"
    match namespace="^tahoe-notification-center$"
    match namespace="^tahoe-left-sidebar$"

    geometry-corner-radius 28

    shadow {
        on
        softness 28
        spread 2
        offset x=0 y=8
        color "#0004"
    }

    // Fallback path (BackgroundEffect.blurRegion). Keep in sync with the
    // tahoe-glass "panel" material so the protocol and fallback look alike.
    background-effect {
        xray false
        blur true
        noise 0.005
        saturation 1.10
        tint-color "#ffffff"
        tint-amount 0.105
        contrast 1.10
        edge-highlight 0.14
        refraction 0.004
        inner-shadow 0.06
        chromatic 0.0
        lens-depth 0.0
    }
}

// Layer animation Control Center profile. The panel opens from the top bar
// using edge-attached motion instead of scaling the whole glass surface.
// The open transform channel deliberately has no transform-duration-ms /
// transform-curve override: it inherits the main-channel spring below.
layer-rule {
    match namespace="^tahoe-control-center$"

    animations {
        layer-open {
            style "edge-reveal"
            edge "top"
            // edge-reveal uses the layer surface extent; distance is not a short-travel knob and is intentionally omitted.
            opacity-from 0.84
            spring damping-ratio=0.85 stiffness=380 epsilon=0.0005
            opacity-duration-ms 110
            opacity-curve "standard-decel"
        }
        layer-close {
            style "edge-reveal"
            edge "top"
            opacity-to 1.0
            transform-duration-ms 210
            transform-curve "emphasized-accel"
            opacity-duration-ms 0
        }
    }
}

// Layer animation Notification Center profile. Keep it consistent with other
// top-bar panels: it opens from the top bar rather than sliding in sideways.
layer-rule {
    match namespace="^tahoe-notification-center$"

    animations {
        layer-open {
            style "edge-reveal"
            edge "top"
            opacity-from 0.86
            spring damping-ratio=0.85 stiffness=380 epsilon=0.0005
            opacity-duration-ms 100
            opacity-curve "standard-decel"
        }
        layer-close {
            style "edge-reveal"
            edge "top"
            opacity-to 1.0
            transform-duration-ms 210
            transform-curve "emphasized-accel"
            opacity-duration-ms 0
        }
    }
}

// Layer animation Left Sidebar profile. This is a full-height, left-anchored
// surface, so use compositor edge reveal with no opacity fade: the glass is
// already blurred from the first visible frame instead of fading in late.
layer-rule {
    match namespace="^tahoe-left-sidebar$"

    animations {
        layer-open {
            style "edge-reveal"
            edge "left"
            opacity-from 1
            spring damping-ratio=0.85 stiffness=380 epsilon=0.0005
            opacity-duration-ms 0
        }
        layer-close {
            style "edge-reveal"
            edge "left"
            opacity-to 1
            transform-duration-ms 180
            transform-curve "emphasized-accel"
            opacity-duration-ms 0
        }
    }
}

// Layer animation Spotlight profile. Launchpad stays on the QML path because
// compositor scaling makes the app grid and glass blur look soft.
layer-rule {
    match namespace="^tahoe-spotlight$"

    animations {
        layer-open {
            style "popin"
            scale-from 0.96
            opacity-from 0
            spring damping-ratio=0.88 stiffness=500 epsilon=0.001
            opacity-duration-ms 120
            opacity-curve "standard-decel"
            origin "center"
        }
        layer-close {
            style "popout"
            scale-to 0.96
            opacity-to 0
            transform-duration-ms 110
            transform-curve "emphasized-accel"
            opacity-duration-ms 80
            opacity-curve "emphasized-accel"
            origin "center"
        }
    }
}

layer-rule {
    match namespace="^tahoe-battery-popup$"
    match namespace="^tahoe-wifi-popup$"
    match namespace="^tahoe-fan-popup$"
    match namespace="^tahoe-clipboard-popup$"

    geometry-corner-radius 24

    shadow {
        on
        softness 28
        spread 2
        offset x=0 y=8
        color "#0004"
    }

    // Fallback path. Keep in sync with the tahoe-glass "panel" material.
    background-effect {
        xray false
        blur true
        noise 0.005
        saturation 1.10
        tint-color "#ffffff"
        tint-amount 0.105
        contrast 1.10
        edge-highlight 0.14
        refraction 0.004
        inner-shadow 0.06
        chromatic 0.0
        lens-depth 0.0
    }
}

// Top-bar status popups and tray menus keep Control Center's full top
// edge-reveal: their layer-shell anchor is the popup's left edge, not the
// clicked button, so popin/pop-slide from anchor would stretch glass wrong.
layer-rule {
    match namespace="^tahoe-battery-popup$"
    match namespace="^tahoe-wifi-popup$"
    match namespace="^tahoe-fan-popup$"
    match namespace="^tahoe-clipboard-popup$"
    match namespace="^tahoe-tray-menu$"

    animations {
        layer-open {
            style "edge-reveal"
            edge "top"
            opacity-from 0.68
            spring damping-ratio=0.85 stiffness=380 epsilon=0.0005
            opacity-duration-ms 110
            opacity-curve "standard-decel"
        }
        layer-close {
            style "edge-reveal"
            edge "top"
            opacity-to 0
            transform-duration-ms 210
            transform-curve "emphasized-accel"
            opacity-duration-ms 120
            opacity-curve "emphasized-accel"
        }
    }
}

// T21/T22: app and shell menus use pop-slide (scale + 4px edge travel) with
// origin "pointer" so they grow from the click that opened them (seat pointer
// at map time; no new protocol). Falls back to center if unavailable.
layer-rule {
    match namespace="^tahoe-menu-popup$"
    match namespace="^tahoe-application-menu$"
    match namespace="^tahoe-process-menu$"
    match namespace="^tahoe-dock-app-menu$"
    match namespace="^tahoe-dock-window-menu$"

    animations {
        layer-open {
            style "pop-slide"
            origin "pointer"
            edge "top"
            distance 4
            scale-from 0.94
            opacity-from 0
            spring damping-ratio=0.88 stiffness=500 epsilon=0.001
            opacity-duration-ms 90
            opacity-curve "standard-decel"
        }
        layer-close {
            style "pop-slide"
            origin "pointer"
            edge "top"
            distance 4
            scale-to 0.98
            opacity-to 0
            transform-duration-ms 180
            transform-curve "emphasized-accel"
            opacity-duration-ms 180
            opacity-curve "emphasized-accel"
        }
    }
}

// Layer animation Toast profile. Toasts slide from the right on a spring
// (the transform channel inherits the main-channel spring) with a short fade
// so they register without pulling focus from the current work.
layer-rule {
    match namespace="^tahoe-notification-toast$"

    animations {
        layer-open {
            style "slide"
            edge "right"
            distance 28
            opacity-from 0.75
            spring damping-ratio=0.8 stiffness=320 epsilon=0.0005
            opacity-duration-ms 100
            opacity-curve "standard-decel"
        }
        layer-close {
            style "slide"
            edge "right"
            distance 22
            opacity-to 0
            transform-duration-ms 110
            transform-curve "emphasized-accel"
            opacity-duration-ms 80
            opacity-curve "emphasized-accel"
        }
    }
}

layer-rule {
    match namespace="^tahoe-menu-popup$"
    match namespace="^tahoe-application-menu$"
    match namespace="^tahoe-tray-menu$"
    match namespace="^tahoe-dock-app-menu$"
    match namespace="^tahoe-dock-window-menu$"
    match namespace="^tahoe-process-menu$"

    geometry-corner-radius 18

    shadow {
        on
        softness 28
        spread 2
        offset x=0 y=8
        color "#0004"
    }

    // Fallback path. Keep in sync with the tahoe-glass "menu" material:
    // stronger edge light, gentler refraction so text stays crisp.
    background-effect {
        xray false
        blur true
        noise 0.004
        saturation 1.08
        tint-color "#ffffff"
        tint-amount 0.110
        contrast 1.11
        edge-highlight 0.26
        refraction 0.004
        inner-shadow 0.10
        chromatic 0.0
        lens-depth 0.0
    }
}

layer-rule {
    match namespace="^tahoe-notification-toast$"

    geometry-corner-radius 18

    shadow {
        on
        softness 28
        spread 2
        offset x=0 y=8
        color "#0004"
    }

    // Fallback path. Keep in sync with the tahoe-glass "toast" material.
    background-effect {
        xray false
        blur true
        noise 0.005
        saturation 1.09
        tint-color "#ffffff"
        tint-amount 0.100
        contrast 1.10
        edge-highlight 0.24
        refraction 0.005
        inner-shadow 0.09
        chromatic 0.0
        lens-depth 0.0
    }
}

// Binds sourced from niri/resources/default-config.kdl. niri does not merge
// default binds with user binds — once a `binds {}` block exists, it is the
// authoritative set — so the full default set is reproduced here to keep the
// Tahoe session's keyboard behavior consistent with the upstream niri entry.
binds {
    // "Mod" is Super on a TTY, Alt when running as a winit window.
    Mod+Shift+Slash { show-hotkey-overlay; }

    Mod+T hotkey-overlay-title="Open a Terminal: alacritty" { spawn "alacritty"; }
    Mod+D hotkey-overlay-title="Run an Application: fuzzel" { spawn "fuzzel"; }
    Super+Alt+L hotkey-overlay-title="Lock the Screen: Tahoe" {
        spawn-sh "lock_helper=\"${TAHOE_CONFIG_DIR:-$HOME/.config/quickshell/tahoe}/scripts/tahoe-lock.sh\"; if [ -r \"$lock_helper\" ]; then exec bash \"$lock_helper\" shortcut; fi; qs_bin=\"${TAHOE_QUICKSHELL_BIN:-$HOME/.local/bin/quickshell}\"; cfg=\"${TAHOE_CONFIG_DIR:-$HOME/.config/quickshell/tahoe}\"; [ -x \"$qs_bin\" ] || qs_bin=quickshell; \"$qs_bin\" ipc -p \"$cfg\" call tahoe lockFrom shortcut >/dev/null 2>&1 || \"$qs_bin\" ipc -p \"$cfg\" call tahoe lock >/dev/null 2>&1 || loginctl lock-session \"${XDG_SESSION_ID:-}\" >/dev/null 2>&1 || { command -v swaylock >/dev/null 2>&1 && exec swaylock; }";
    }

    Super+Alt+S allow-when-locked=true hotkey-overlay-title=null { spawn-sh "pkill orca || exec orca"; }

    XF86AudioRaiseVolume allow-when-locked=true { spawn-sh "wpctl set-volume @DEFAULT_AUDIO_SINK@ 0.1+ -l 1.0"; }
    XF86AudioLowerVolume allow-when-locked=true { spawn-sh "wpctl set-volume @DEFAULT_AUDIO_SINK@ 0.1-"; }
    XF86AudioMute        allow-when-locked=true { spawn-sh "wpctl set-mute @DEFAULT_AUDIO_SINK@ toggle"; }
    XF86AudioMicMute     allow-when-locked=true { spawn-sh "wpctl set-mute @DEFAULT_AUDIO_SOURCE@ toggle"; }

    XF86AudioPlay        allow-when-locked=true { spawn-sh "playerctl play-pause"; }
    XF86AudioPause       allow-when-locked=true { spawn-sh "playerctl play-pause"; }
    XF86AudioStop        allow-when-locked=true { spawn-sh "playerctl stop"; }
    XF86AudioPrev        allow-when-locked=true { spawn-sh "playerctl previous"; }
    XF86AudioNext        allow-when-locked=true { spawn-sh "playerctl next"; }

    XF86MonBrightnessUp allow-when-locked=true { spawn "brightnessctl" "--class=backlight" "set" "+10%"; }
    XF86MonBrightnessDown allow-when-locked=true { spawn "brightnessctl" "--class=backlight" "set" "10%-"; }

    Mod+O repeat=false { toggle-overview; }
    Mod+Ctrl+Tab repeat=false hotkey-overlay-title="Tahoe Window Switcher" {
        spawn-sh "qs_bin=\"${TAHOE_QUICKSHELL_BIN:-$HOME/.local/bin/quickshell}\"; cfg=\"${TAHOE_CONFIG_DIR:-$HOME/.config/quickshell/tahoe}\"; [ -x \"$qs_bin\" ] || qs_bin=quickshell; \"$qs_bin\" ipc -p \"$cfg\" call tahoe cycleTaskSwitcher 1 >/dev/null 2>&1 || true";
    }
    Mod+Ctrl+Shift+Tab repeat=false hotkey-overlay-title="Tahoe Window Switcher Previous" {
        spawn-sh "qs_bin=\"${TAHOE_QUICKSHELL_BIN:-$HOME/.local/bin/quickshell}\"; cfg=\"${TAHOE_CONFIG_DIR:-$HOME/.config/quickshell/tahoe}\"; [ -x \"$qs_bin\" ] || qs_bin=quickshell; \"$qs_bin\" ipc -p \"$cfg\" call tahoe cycleTaskSwitcher -1 >/dev/null 2>&1 || true";
    }
    Mod+Shift+O repeat=false hotkey-overlay-title="Tahoe Window Overview" {
        spawn-sh "qs_bin=\"${TAHOE_QUICKSHELL_BIN:-$HOME/.local/bin/quickshell}\"; cfg=\"${TAHOE_CONFIG_DIR:-$HOME/.config/quickshell/tahoe}\"; [ -x \"$qs_bin\" ] || qs_bin=quickshell; \"$qs_bin\" ipc -p \"$cfg\" call tahoe toggleWindowOverview >/dev/null 2>&1 || true";
    }

    Mod+Q repeat=false { close-window; }

    Mod+Left  { focus-column-left; }
    Mod+Down  { focus-window-down; }
    Mod+Up    { focus-window-up; }
    Mod+Right { focus-column-right; }
    Mod+H     { focus-column-left; }
    Mod+J     { focus-window-down; }
    Mod+K     { focus-window-up; }
    Mod+L     { focus-column-right; }

    Mod+Ctrl+Left  { move-column-left; }
    Mod+Ctrl+Down  { move-window-down; }
    Mod+Ctrl+Up    { move-window-up; }
    Mod+Ctrl+Right { move-column-right; }
    Mod+Ctrl+H     { move-column-left; }
    Mod+Ctrl+J     { move-window-down; }
    Mod+Ctrl+K     { move-window-up; }
    Mod+Ctrl+L     { move-column-right; }

    Mod+Home { focus-column-first; }
    Mod+End  { focus-column-last; }
    Mod+Ctrl+Home { move-column-to-first; }
    Mod+Ctrl+End  { move-column-to-last; }

    Mod+Shift+Left  { focus-monitor-left; }
    Mod+Shift+Down  { focus-monitor-down; }
    Mod+Shift+Up    { focus-monitor-up; }
    Mod+Shift+Right { focus-monitor-right; }
    Mod+Shift+H     { focus-monitor-left; }
    Mod+Shift+J     { focus-monitor-down; }
    Mod+Shift+K     { focus-monitor-up; }
    Mod+Shift+L     { focus-monitor-right; }

    Mod+Shift+Ctrl+Left  { move-column-to-monitor-left; }
    Mod+Shift+Ctrl+Down  { move-column-to-monitor-down; }
    Mod+Shift+Ctrl+Up    { move-column-to-monitor-up; }
    Mod+Shift+Ctrl+Right { move-column-to-monitor-right; }
    Mod+Shift+Ctrl+H     { move-column-to-monitor-left; }
    Mod+Shift+Ctrl+J     { move-column-to-monitor-down; }
    Mod+Shift+Ctrl+K     { move-column-to-monitor-up; }
    Mod+Shift+Ctrl+L     { move-column-to-monitor-right; }

    Mod+Page_Down      { focus-workspace-down; }
    Mod+Page_Up        { focus-workspace-up; }
    Mod+U              { focus-workspace-down; }
    Mod+I              { focus-workspace-up; }
    Mod+Ctrl+Page_Down { move-column-to-workspace-down; }
    Mod+Ctrl+Page_Up   { move-column-to-workspace-up; }
    Mod+Ctrl+U         { move-column-to-workspace-down; }
    Mod+Ctrl+I         { move-column-to-workspace-up; }

    Mod+Shift+Page_Down { move-workspace-down; }
    Mod+Shift+Page_Up   { move-workspace-up; }
    Mod+Shift+U         { move-workspace-down; }
    Mod+Shift+I         { move-workspace-up; }

    Mod+WheelScrollDown      cooldown-ms=150 { focus-workspace-down; }
    Mod+WheelScrollUp        cooldown-ms=150 { focus-workspace-up; }
    Mod+Ctrl+WheelScrollDown cooldown-ms=150 { move-column-to-workspace-down; }
    Mod+Ctrl+WheelScrollUp   cooldown-ms=150 { move-column-to-workspace-up; }

    Mod+WheelScrollRight      { focus-column-right; }
    Mod+WheelScrollLeft       { focus-column-left; }
    Mod+Ctrl+WheelScrollRight { move-column-right; }
    Mod+Ctrl+WheelScrollLeft  { move-column-left; }

    Mod+Shift+WheelScrollDown      { focus-column-right; }
    Mod+Shift+WheelScrollUp        { focus-column-left; }
    Mod+Ctrl+Shift+WheelScrollDown { move-column-right; }
    Mod+Ctrl+Shift+WheelScrollUp   { move-column-left; }

    Mod+1 { focus-workspace 1; }
    Mod+2 { focus-workspace 2; }
    Mod+3 { focus-workspace 3; }
    Mod+4 { focus-workspace 4; }
    Mod+5 { focus-workspace 5; }
    Mod+6 { focus-workspace 6; }
    Mod+7 { focus-workspace 7; }
    Mod+8 { focus-workspace 8; }
    Mod+9 { focus-workspace 9; }
    Mod+Ctrl+1 { move-column-to-workspace 1; }
    Mod+Ctrl+2 { move-column-to-workspace 2; }
    Mod+Ctrl+3 { move-column-to-workspace 3; }
    Mod+Ctrl+4 { move-column-to-workspace 4; }
    Mod+Ctrl+5 { move-column-to-workspace 5; }
    Mod+Ctrl+6 { move-column-to-workspace 6; }
    Mod+Ctrl+7 { move-column-to-workspace 7; }
    Mod+Ctrl+8 { move-column-to-workspace 8; }
    Mod+Ctrl+9 { move-column-to-workspace 9; }

    Mod+BracketLeft  { consume-or-expel-window-left; }
    Mod+BracketRight { consume-or-expel-window-right; }

    Mod+Comma  { consume-window-into-column; }
    Mod+Period { expel-window-from-column; }

    Mod+R { switch-preset-column-width; }
    Mod+Shift+R { switch-preset-column-width-back; }

    Mod+Ctrl+Shift+R { switch-preset-window-height; }
    Mod+Ctrl+R { reset-window-height; }

    Mod+F { maximize-column; }
    Mod+Shift+F { fullscreen-window; }

    Mod+M { maximize-window-to-edges; }

    Mod+Ctrl+F { expand-column-to-available-width; }

    Mod+C { center-column; }

    Mod+Ctrl+C { center-visible-columns; }

    Mod+Minus { set-column-width "-10%"; }
    Mod+Equal { set-column-width "+10%"; }

    Mod+Shift+Minus { set-window-height "-10%"; }
    Mod+Shift+Equal { set-window-height "+10%"; }

    Mod+V       { toggle-window-floating; }
    Mod+Shift+V { switch-focus-between-floating-and-tiling; }

    Mod+W { toggle-column-tabbed-display; }

    Print { screenshot; }
    Ctrl+Print { screenshot-screen; }
    Alt+Print { screenshot-window; }

    Mod+Escape allow-inhibiting=false { toggle-keyboard-shortcuts-inhibit; }

    Mod+Shift+E { quit; }
    Ctrl+Alt+Delete { quit; }

    Mod+Shift+P { power-off-monitors; }
}
